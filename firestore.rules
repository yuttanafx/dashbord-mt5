rules_version = '2';

// Security Rules สำหรับ Firestore
// อนุญาตให้เฉพาะผู้ที่ "ล็อกอินแล้ว" เท่านั้นที่อ่าน/เขียนข้อมูลได้
// เหมาะกับธุรกิจที่มีพนักงาน/หุ้นส่วนหลายคนใช้ข้อมูลร่วมกันชุดเดียว
// (ทุกคนที่มีบัญชี Firebase Auth ที่คุณสร้างให้ จะเห็นข้อมูลเดียวกันทั้งหมด)

service cloud.firestore {
  match /databases/{database}/documents {
    match /workspaces/{workspaceId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
